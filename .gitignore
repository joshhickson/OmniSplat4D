# ============================================================
# OmniSplat4D .gitignore
# ============================================================

# Runtime workspace — gigabytes of binary artifacts, never commit
workspace/

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg

# Virtual environments
.venv/
venv/
env/
.env

# Editable install metadata
*.dist-info/

# Model weights — download separately, too large for git
*.pt
*.pth
*.safetensors
*.ckpt

# Generated artifacts
*.onnx
*.spz
*.ply

# COLMAP
*.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Coverage / test artifacts
.coverage
htmlcov/
.pytest_cache/
